# Vida RB2B webhook receiver — environment variables
# Copy to .env for local runs. On Railway, set these in the service Variables tab.
# These EXACT names are what the service reads (config.py). Match them in Railway.

# ── Secrets (you supply the values) ──────────────────────────────────────────
ANTHROPIC_API_KEY=
AI_ARK_API_KEY=
EMAILBISON_API_KEY=
SLACK_BOT_TOKEN=
# Shared secret that must appear as ?token=<this> on the webhook URL.
RB2B_WEBHOOK_TOKEN=

# ── EmailBison target (defaults match the addendum; override only if needed) ──
EMAILBISON_WORKSPACE_ID=29
EMAILBISON_BASE_URL=https://personal.buzzlead.io
EMAILBISON_CAMPAIGN_NAME=Vida - RB2B Website Visitors

# ── Slack ────────────────────────────────────────────────────────────────────
SLACK_CHANNEL=#vida-buzzlead-private-channel
SLACK_DIGEST_INTERVAL_SECONDS=900

# ── Optional tuning ──────────────────────────────────────────────────────────
# Override the model pinned in the approved prompt files (only if it's retired).
COPY_MODEL=
DEDUPE_WINDOW_HOURS=24
# Point these at a mounted Railway volume to persist across deploys.
# DB_PATH=/data/rb2b.db
# DATA_DIR=/data
# DRY_RUN=1   # set only for local replay via scripts/dry_run.py
